<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.trustlens">

    <application
        android:allowBackup="true"
        android:label="TrustLens"
        android:theme="@style/Theme.TrustLens">
        <!-- main activity -->
        <activity android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Login Activity (First Screen) -->
        <activity android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Home Activity (After Login) -->
        <activity android:name=".HomeActivity" />
        <activity android:name=".AnalyzeActivity" />

        <activity android:name=".TrustAnalysisActivity" />
        <activity android:name=".ReportIssueActivity" />
        <activity android:name=".ReportSuccessActivity" />
        <activity android:name=".RiskDetailsActivity" />


    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>

        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MADFIREBASE">


    </application>

</manifest>