<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background fill (light orange or transparent) -->
    <solid android:color="#FFF3E0"/> <!-- very light orange, use #FFFFFF for pure white -->

    <!-- Orange outline -->
    <stroke
        android:width="2dp"
        android:color="#FF9800"/> <!-- orange border -->

    <!-- Rounded corners -->
    <corners android:radius="8dp"/>
</shape>
