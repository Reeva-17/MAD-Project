<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradient background -->
    <gradient
        android:startColor="#FF6A00"
        android:endColor="#9B00FF"
        android:centerColor="#FF3D7F"
        android:angle="135"
        android:type="linear" />

    <!-- Rounded corners -->
    <corners android:radius="24dp" />

    <!-- Optional stroke -->
    <stroke android:width="1dp" android:color="#33000000" />

    <!-- Padding for text -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />
</shape>