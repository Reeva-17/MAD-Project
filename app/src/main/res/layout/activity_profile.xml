<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER SECTION (Image 1) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:background="@drawable/profile_header_bg"
            android:padding="20dp">

            <ImageView
                android:id="@+id/backButtonProfile"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@drawable/white_circle"
                android:backgroundTint="#40FFFFFF"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_left"
                app:tint="@color/white"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/settingsButtonProfile"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/white_circle"
                android:backgroundTint="#40FFFFFF"
                android:padding="8dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/white"
                android:clickable="true"
                android:focusable="true"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="30dp"
                android:gravity="center"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="10dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/profile1"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:text="Alex Johnson"
                    android:id="@+id/profileName"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="alex.johnson@email.com"
                    android:id="@+id/profileEmail"
                    android:textColor="#E0E0E0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Member since January 2024"
                    android:textColor="#BDBDBD"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- STATS CARDS (Analyses, Reports, Saved) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-50dp"
            android:paddingHorizontal="20dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Card 1: Analyses -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:id="@+id/analysesCount"
                android:layout_weight="1"
                android:layout_margin="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#2196F3" android:background="#E3F2FD" android:padding="5dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="47" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="5dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Analyses" android:textSize="12sp" android:textColor="@color/gray_text"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Reports -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:id="@+id/reportsCount"
                android:layout_margin="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@android:drawable/ic_menu_view" app:tint="#F44336" android:background="#FFEBEE" android:padding="5dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="5dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reports" android:textSize="12sp" android:textColor="@color/gray_text"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Saved -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:id="@+id/savedCount"
                android:layout_margin="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@android:drawable/ic_menu_save" app:tint="#9C27B0" android:background="#F3E5F5" android:padding="5dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="23" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="5dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Saved" android:textSize="12sp" android:textColor="@color/gray_text"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- YOUR BADGES (Image 2) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:layout_marginStart="20dp"
            android:text="🏆 Your Badges"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="15dp"
            android:weightSum="3">

            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="5dp" app:cardBackgroundColor="#FFA000" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="25sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trusted\nReporter" android:gravity="center" android:textColor="@color/white" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="5dp" app:cardBackgroundColor="#FFC107" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛡️" android:textSize="25sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Safety\nAdvocate" android:gravity="center" android:textColor="@color/white" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:layout_margin="5dp" app:cardBackgroundColor="#E0E0E0" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="25sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Community\nGuardian" android:gravity="center" android:textColor="#757575" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- SAVED PRODUCTS (Image 2) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:text="📦 Saved Products"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:id="@+id/savedContainer"
            android:padding="15dp">

            <!-- Product Item -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProduct1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:clickable="true"
                android:focusable="true">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp">
                    <androidx.cardview.widget.CardView android:id="@+id/pImg" android:layout_width="60dp" android:layout_height="60dp" app:cardCornerRadius="8dp" app:cardElevation="0dp">
                        <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F5F5F5" android:src="@drawable/oip"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/pImg" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Premium Jacket" android:textStyle="bold" android:textColor="@color/black" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@fashion_store" android:textColor="@color/gray_text" android:textSize="14sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="35dp" android:layout_height="35dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/score_circle" android:gravity="center" android:text="92" android:textColor="@color/white" android:textStyle="bold" android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardProduct2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:clickable="true"
                android:focusable="true">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp">
                    <androidx.cardview.widget.CardView android:id="@+id/smartwatch" android:layout_width="60dp" android:layout_height="60dp" app:cardCornerRadius="8dp" app:cardElevation="0dp">
                        <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F5F5F5" android:src="@drawable/smartwatch"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/smartwatch" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Smart Watch" android:textStyle="bold" android:textColor="@color/black" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@tech_deals" android:textColor="@color/gray_text" android:textSize="14sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="35dp" android:layout_height="35dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/score_circle" android:gravity="center" android:text="95" android:textColor="@color/white" android:textStyle="bold" android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardProduct3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:clickable="true"
                android:focusable="true">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp">
                    <androidx.cardview.widget.CardView android:id="@+id/runningshoes" android:layout_width="60dp" android:layout_height="60dp" app:cardCornerRadius="8dp" app:cardElevation="0dp">
                        <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F5F5F5" android:src="@drawable/runningshoes"/>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/runningshoes" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Running Shoes" android:textStyle="bold" android:textColor="@color/black" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@sneaker_hub" android:textColor="@color/gray_text" android:textSize="14sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="35dp" android:layout_height="35dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/score_circle" android:gravity="center" android:text="85" android:textColor="@color/white" android:textStyle="bold" android:textSize="12sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView

                android:id="@+id/btnViewPurchased"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#6200EE">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/btn_detailed_gradient" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="View Purchased Products →"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textSize="16sp" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>