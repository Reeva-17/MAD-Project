<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_hero_gradient"
    android:outlineProvider="background"
    android:clipToOutline="true">

    <include
        android:id="@+id/header_bar"
        layout="@layout/layout_header_bar"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="@dimen/spacing_base"
        android:paddingBottom="48dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="@dimen/store_icon_container"
                android:layout_height="@dimen/store_icon_container"
                android:background="@drawable/store_icon">

                <ImageView
                    android:id="@+id/store_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_store"
                    android:contentDescription="@string/cd_store_icon"/>
            </FrameLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tv_dashboard_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/seller_dashboard"
                    android:textSize="@dimen/text_h2"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_dashboard_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/instagram_business_trust_checker"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/white_80"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tv_store_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/store_name"
                    android:textSize="@dimen/text_h3"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/store_handle"
                    android:textSize="@dimen/text_small"
                    android:textColor="@color/white_80"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_view_store"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/view_store_btn"
                android:paddingStart="@dimen/spacing_xl"
                android:paddingEnd="@dimen/spacing_xl"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="@dimen/spacing_base"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_store"
                    android:importantForAccessibility="no"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_store"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/white"
                    android:layout_marginStart="@dimen/spacing_sm"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

        </LinearLayout>


