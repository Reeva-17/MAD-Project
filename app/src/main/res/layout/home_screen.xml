<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Top bar -->

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@drawable/setting_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">


        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profileButton"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:contentDescription="Profile"
            android:focusable="true"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_profile_foreground"
            app:shapeAppearanceOverlay="@style/CircleImageStyle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TrustLens"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:gravity="center_horizontal"
            android:textStyle="bold" />


        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="72dp"
            android:layout_height="78dp"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:contentDescription="Settings"
            android:src="@drawable/settings_logo"
            app:tint="#FFFFFF" />




    </LinearLayout>

    <!-- Search Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/search_bg"
        android:padding="12dp"
        android:layout_margin="16dp"
        android:gravity="center_vertical"
        android:elevation="7dp">

        <!-- Search Icon -->
        <ImageView
            android:id="@+id/searchIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search Icon"
            android:layout_marginEnd="2dp"/>

        <!-- Search Text Field -->
        <EditText
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search Instagram business or product..."
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- Scam Protection Card -->
    <LinearLayout
        android:id="@+id/scamCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_card"
        android:elevation="10dp"
        android:padding="10dp"
        android:layout_margin="16dp"
        android:gravity="center_vertical">

        <!-- Placeholder for Green Image -->
        <ImageView
            android:id="@+id/scamIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@mipmap/ic_shield_round"
            android:contentDescription="Scam Protection Icon"
            app:tint="#4CAF50"
        android:layout_marginEnd="12dp"/>

        <!-- Text Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title in Black -->
            <TextView
                android:id="@+id/scamTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay safe from scams"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <!-- Subtitle in Grey -->
            <TextView
                android:id="@+id/scamSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI powered protection"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>



    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Categories -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textSize="18sp"
                android:textStyle="bold"

                android:padding="8dp" />

            <!-- Recommended Products -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/catWomen"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:background="@drawable/card_bg"
                        android:elevation="4dp"
                        android:text="Women Clothes" />

                    <Button
                        android:id="@+id/catMen"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:background="@drawable/card_bg"
                        android:elevation="4dp"
                        android:text="Men Clothes" />

                    <Button
                        android:id="@+id/catKids"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Kids Clothes"
                        android:background="@drawable/card_bg"
                        android:elevation="4dp"/>

                    <Button
                        android:id="@+id/catAccessories"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Accessories"
                        android:background="@drawable/card_bg"
                        android:elevation="4dp"/>

                    <Button
                        android:id="@+id/catCrochet"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Crochet"
                        android:background="@drawable/card_bg"
                        android:elevation="4dp"/>

                    <Button
                        android:id="@+id/catDecor"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Decor Items"
                        android:background="@drawable/card_bg"
                        android:elevation="4dp"/>


                        />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recommended Products"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="8dp" />

            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Product Card 1 -->
                <LinearLayout
                    android:id="@+id/productCard1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Product Image -->
                    <ImageView
                        android:id="@+id/productImage1"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_jacket_foreground"
                        android:scaleType="centerCrop"/>

                    <!-- Product Name -->
                    <TextView
                        android:id="@+id/productName1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Premium Jacket"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"/>

                    <!-- Seller Name -->
                    <TextView
                        android:id="@+id/productSeller1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@fashion_store"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <!-- Price + Rating -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"

                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/productPrice1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="700/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <TextView
                            android:id="@+id/productRating1"
                            android:layout_width="36dp"
                            android:layout_height="36dp"

                            android:gravity="center"
                            android:text="92"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Product Card 2 -->
                <LinearLayout
                    android:id="@+id/productCard2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Product Image -->
                    <ImageView
                        android:id="@+id/productImage2"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_skincare_foreground"
                        android:scaleType="centerCrop"/>

                    <!-- Product Name -->
                    <TextView
                        android:id="@+id/productName2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skincare Set"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <!-- Seller Name -->
                    <TextView
                        android:id="@+id/productSeller2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@beauty_essentials"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <!-- Price + Rating -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"

                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/productPrice2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1000/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <TextView
                            android:id="@+id/productRating2"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="78"
                            android:textColor="#FFFFFF"
                            android:background="#FF9800"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>


            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Product Card 3 -->
                <LinearLayout
                    android:id="@+id/productCard3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Product Image -->
                    <ImageView
                        android:id="@+id/productImage3"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_shoes_foreground"
                        android:scaleType="centerCrop"/>

                    <!-- Product Name -->
                    <TextView
                        android:id="@+id/productName3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Running Shoes"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <!-- Seller Name -->
                    <TextView
                        android:id="@+id/productSeller3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@sneaker_hub"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <!-- Price + Rating Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <!-- Price on Left -->
                        <TextView
                            android:id="@+id/productPrice3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="800/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <!-- Rating on Right -->
                        <TextView
                            android:id="@+id/productRating3"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="85"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Product Card 4 -->
                <LinearLayout
                    android:id="@+id/productCard4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Product Image -->
                    <ImageView
                        android:id="@+id/productImage4"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_watch_foreground"
                        android:scaleType="centerCrop"/>

                    <!-- Product Name -->
                    <TextView
                        android:id="@+id/productName4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Watch"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <!-- Seller Name -->
                    <TextView
                        android:id="@+id/productSeller4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@tech_deals"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <!-- Price + Rating Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <!-- Price on Left -->
                        <TextView
                            android:id="@+id/productPrice4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1500/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <!-- Rating on Right -->
                        <TextView
                            android:id="@+id/productRating4"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="96"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Product Card 5 -->
                <LinearLayout
                    android:id="@+id/productCard5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/productImage5"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_shirt_foreground"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:id="@+id/productName5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Casual Shirt"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:id="@+id/productSeller5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@fashion_store"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/productPrice5"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="435/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <TextView
                            android:id="@+id/productRating5"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="80"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Product Card 6 -->
                <LinearLayout
                    android:id="@+id/productCard6"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/productImage6"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_perfume_foreground"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:id="@+id/productName6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Perfume"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:id="@+id/productSeller6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@beauty_essentials"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/productPrice6"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="234/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <TextView
                            android:id="@+id/productRating6"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="72"
                            android:textColor="#FFFFFF"
                            android:background="#F44336"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Product Card 7 -->
                <LinearLayout
                    android:id="@+id/productCard7"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/productImage7"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_headphones_foreground"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:id="@+id/productName7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Headphones"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:id="@+id/productSeller7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@tech_deals"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/productPrice7"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="2530/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <TextView
                            android:id="@+id/productRating7"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="90"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Product Card 8 -->
                <LinearLayout
                    android:id="@+id/productCard8"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/productImage8"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_sneakers_foreground"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:id="@+id/productName8"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sneakers"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:id="@+id/productSeller8"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@sneaker_hub"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/productPrice8"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="950/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <TextView
                            android:id="@+id/productRating8"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="84"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>



        </LinearLayout>
    </ScrollView>
</LinearLayout>