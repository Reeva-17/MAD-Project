<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_sm">

        <TextView
            android:id="@+id/tv_perf_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:textSize="@dimen/text_body"
            android:textColor="@color/foreground"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_perf_values"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:textSize="@dimen/text_small"
            android:textColor="@color/muted_foreground"
            android:fontFamily="monospace"/>
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/progress_bar_height"
        android:background="@drawable/bg_progress_track">

        <View
            android:id="@+id/view_progress_fill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_progress_fill_tertiary"/>
    </FrameLayout>
</LinearLayout>

