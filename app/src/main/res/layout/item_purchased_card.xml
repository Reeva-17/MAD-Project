<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Purchased Products"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage your recent purchases and reviews"
            android:textColor="#7A7A7A"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- PRODUCT 1: Running Shoes -->
        <androidx.cardview.widget.CardView
            android:id="@+id/purchasedCard1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardMaxElevation="12dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@android:color/white">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/imgProduct1"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/runningshoes" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgProduct1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Running Shoes"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#1A1A1A"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Order #SH-1022 • April 10"
                            android:textColor="#999"
                            android:textSize="12sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="#E8F5E9"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="Delivered"
                            android:textColor="#2E7D32"
                            android:textStyle="bold"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginVertical="18dp"/>

                <!-- Star Rating Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rate &amp; Review"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#6200EE"/>

                <RatingBar
                    android:id="@+id/rating1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:numStars="5"
                    android:progressTint="#FFD700"
                    android:rating="0"
                    android:stepSize="1"
                    android:isIndicator="false" />

                <EditText
                    android:id="@+id/etReview1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Share your experience..."
                    android:background="#F8F9FB"
                    android:padding="12dp"
                    android:layout_marginTop="12dp"
                    android:textSize="14sp"
                    android:textColor="#333"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <Button
                        android:id="@+id/btnSubmit1"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:backgroundTint="#6200EE"
                        android:text="Submit"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="20dp" />

                    <TextView
                        android:id="@+id/btnReportItem1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Report Item"
                        android:textColor="#E53935"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- PRODUCT 2: Smart Watch -->
        <androidx.cardview.widget.CardView
            android:id="@+id/purchasedCard2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@android:color/white">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/imgProduct2"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/smartwatch" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgProduct2"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Smart Watch"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#1A1A1A"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Order #WT-5510 • April 08"
                            android:textColor="#999"
                            android:textSize="12sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="#E8F5E9"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="Delivered"
                            android:textColor="#2E7D32"
                            android:textStyle="bold"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginVertical="18dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rate &amp; Review"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#6200EE"/>

                <RatingBar
                    android:id="@+id/rating2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:numStars="5"
                    android:progressTint="#FFD700"
                    android:rating="0"
                    android:stepSize="1"
                    android:isIndicator="false" />

                <EditText
                    android:id="@+id/etReview2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Rate the watch performance..."
                    android:background="#F8F9FB"
                    android:padding="12dp"
                    android:layout_marginTop="12dp"
                    android:textSize="14sp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">
                    <Button
                        android:id="@+id/btnSubmit2"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:backgroundTint="#6200EE"
                        android:text="Submit"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="20dp" />
                    <TextView
                        android:id="@+id/btnReportItem2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Report Item"
                        android:textColor="#E53935"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- PRODUCT 3: Premium Jacket -->
        <androidx.cardview.widget.CardView
            android:id="@+id/purchasedCard3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@android:color/white">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/imgProduct3"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/oip" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgProduct3"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Premium Jacket"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#1A1A1A"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Order #JK-8821 • April 12"
                            android:textColor="#999"
                            android:textSize="12sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="#FFF3E0"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="In Transit"
                            android:textColor="#EF6C00"
                            android:textStyle="bold"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginVertical="18dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rate &amp; Review"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#6200EE"/>

                <RatingBar
                    android:id="@+id/rating3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:numStars="5"
                    android:progressTint="#FFD700"
                    android:rating="0"
                    android:stepSize="1"
                    android:isIndicator="false" />

                <EditText
                    android:id="@+id/etReview3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Review quality of material..."
                    android:background="#F8F9FB"
                    android:padding="12dp"
                    android:layout_marginTop="12dp"
                    android:textSize="14sp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">
                    <Button
                        android:id="@+id/btnSubmit3"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:backgroundTint="#6200EE"
                        android:text="Submit"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="20dp" />
                    <TextView
                        android:id="@+id/btnReportItem3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Report Item"
                        android:textColor="#E53935"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>