<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/header_min_height"
    android:paddingStart="@dimen/spacing_xl"
    android:paddingEnd="@dimen/spacing_xl"
    android:background="@color/transparent">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="@dimen/icon_btn_size"
        android:layout_height="@dimen/icon_btn_size"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_arrow_left"
        android:background="@android:color/transparent"
        android:contentDescription="@string/cd_go_back"
        android:padding="@dimen/spacing_sm"/>

    <TextView
        android:id="@+id/tv_header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="@string/seller_dashboard"
        android:textSize="@dimen/text_body"
        android:textColor="@color/white"
        android:textStyle="bold"/>

    <ImageButton
        android:id="@+id/btn_settings"
        android:layout_width="@dimen/icon_btn_size"
        android:layout_height="@dimen/icon_btn_size"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_settings"
        android:background="@android:color/transparent"
    android:contentDescription="@string/cd_settings"
        android:padding="@dimen/spacing_sm"/>
</RelativeLayout>
