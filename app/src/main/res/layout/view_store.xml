<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <!-- Hero Section -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/setting_gradient"
                android:orientation="vertical"
                android:padding="40dp">


                <!-- Seller Dashboard Top Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <!-- Arrow button on left -->
                    <ImageButton
                        android:id="@+id/backButton"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:background="@color/transparent"
                        android:src="@drawable/back"
                        android:contentDescription="back"
                        app:tint="@color/white"
                        />

                    <!-- Dashboard Title (center, expands with weight) -->
                    <TextView
                        android:id="@+id/tv_dashboard_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="View Store"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <!-- Settings button on right -->
                    <ImageButton
                        android:id="@+id/btn_settings_dashboard"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/settings_logo"
                        android:background="@android:color/transparent"
                        android:contentDescription="Settings"
                        app:tint="@color/white"/>
                </LinearLayout>
                <!-- Store DP + Name side by side -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp">


                    <!-- Profile Image -->
                    <ImageView
                        android:id="@+id/imageView2"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:contentDescription="image"
                        app:srcCompat="@mipmap/ic_launcher_foreground"
                        android:visibility="visible"/>

                    <!-- Store Name -->

                    <TextView
                        android:id="@+id/tv_store_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  Fashion Store"
                        android:textColor="@color/white"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:layout_gravity="center"/>
                </LinearLayout>

                <!-- Store Handle -->
                <TextView
                    android:id="@+id/tv_store_handle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/@fashion_store"
                    android:textColor="@color/white_80"
                    android:textSize="14sp"

                    android:layout_marginTop="6dp"/>
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Products"
                android:elevation="4dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="8dp" />

            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Product Card 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Product Image -->
                    <ImageView
                        android:id="@+id/productImage1"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_jacket_foreground"
                        android:scaleType="centerCrop"/>

                    <!-- Product Name -->
                    <TextView
                        android:id="@+id/productName1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Premium Jacket"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"/>

                    <!-- Seller Name -->
                    <TextView
                        android:id="@+id/productSeller1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@fashion_store"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <!-- Price + Rating -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"

                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="700/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <TextView
                            android:id="@+id/productRating1"
                            android:layout_width="36dp"
                            android:layout_height="36dp"

                            android:gravity="center"
                            android:text="92"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Product Card 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Product Image -->
                    <ImageView
                        android:id="@+id/productImage2"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_top2_foreground"
                        android:scaleType="centerCrop"/>

                    <!-- Product Name -->
                    <TextView
                        android:id="@+id/productName2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Women's Top"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <!-- Seller Name -->
                    <TextView
                        android:id="@+id/productSeller2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@fashion_store"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <!-- Price + Rating -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"

                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="275/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <TextView
                            android:id="@+id/productRating2"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="78"
                            android:textColor="#FFFFFF"
                            android:background="#FF9800"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>


            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Product Card 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp">

                    <!-- Product Image -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_frock_foreground"
                        android:scaleType="centerCrop"/>

                    <!-- Product Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Girl's Frock"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <!-- Seller Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@fashion_store"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <!-- Price + Rating Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <!-- Price on Left -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="548/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <!-- Rating on Right -->
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="85"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Product Card 4 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:layout_marginStart="8dp">

                    <!-- Product Image -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_top_foreground"
                        android:scaleType="centerCrop"/>

                    <!-- Product Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Women Top"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <!-- Seller Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@fashion_store"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <!-- Price + Rating Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <!-- Price on Left -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="345/-"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <!-- Rating on Right -->
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="96"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Product Card: Casual Shirt (Left Side) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:elevation="4dp">

                    <!-- Product Image -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:src="@mipmap/ic_shirt_foreground"
                        android:scaleType="centerCrop"/>

                    <!-- Product Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Casual Shirt"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>

                    <!-- Seller Handle -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@fashion_store"
                        android:textSize="12sp"
                        android:textColor="#666666"/>

                    <!-- Price + Rating Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <!-- Price on Left -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="₹435"
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                        <!-- Rating Badge on Right -->
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="85"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Right Side Blank -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>